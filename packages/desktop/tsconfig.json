{
  // T-1701 · Electron main + preload compile to CommonJS. The Electron main
  // process is a CJS runtime, and `packages/desktop` deliberately does NOT set
  // `"type": "module"` in its package.json, so the emitted `.js` files are CJS —
  // loadable by Electron without an ESM interop shim. This overrides the root
  // solution's NodeNext module setting for this package only.
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "types": ["node"],
    "lib": ["ESNext"]
  },
  // T-1702 · The Steam achievement/presence derivation and cloud-sync helpers read
  // `DEEDS`/`STAR_SYSTEMS` (content) and the `GameEvent` type (engine), so this project
  // now references both — `tsc -b` builds them first and resolves their declarations.
  "references": [{ "path": "../content" }, { "path": "../engine" }],
  "include": ["src/**/*"]
}
