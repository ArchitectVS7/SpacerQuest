# SpacerQuest v4.0 - Environment Variables

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://spacerquest:spacerquest@localhost:5454/spacerquest

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=dev-secret-change-in-production-min-32-chars

# OAuth (BBS Portal) - Mock for development
BBS_PORTAL_CLIENT_ID=dev-client-id
BBS_PORTAL_CLIENT_SECRET=dev-client-secret
BBS_PORTAL_AUTH_URL=http://localhost:3000/auth/mock
BBS_PORTAL_TOKEN_URL=http://localhost:3000/auth/mock/token
BBS_PORTAL_CALLBACK_URL=http://localhost:3000/auth/callback
BBS_PORTAL_USERINFO_URL=http://localhost:3000/auth/mock/userinfo

# Frontend
VITE_WS_URL=ws://localhost:3000
VITE_API_URL=http://localhost:3000

# Game Configuration
DAILY_TRIP_LIMIT=3
ENCOUNTER_CHANCE=0.3
PORT_EVICTION_DAYS=30

# Logging
LOG_LEVEL=info
