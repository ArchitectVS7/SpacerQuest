// SpacerQuest v4.0 - Database Schema
// Based on original SpacerQuest v3.4 by Firefox (1991)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// USER & AUTHENTICATION
// ============================================================================

model User {
  id            String    @id @default(uuid())
  bbsUserId     String    @unique  // OAuth provider user ID
  email         String    @unique
  displayName   String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastLoginAt   DateTime?
  isAdmin       Boolean   @default(false)
  hasConquered  Boolean   @default(false)

  characters    Character[]
  sessions      Session[]
  
  @@index([bbsUserId])
}

model Session {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  token           String    @unique
  expiresAt       DateTime
  ipAddress       String?
  userAgent       String?
  
  createdAt       DateTime  @default(now())
  
  @@index([userId])
  @@index([token])
}

// ============================================================================
// CHARACTER & PROGRESSION
// ============================================================================

enum Rank {
  LIEUTENANT
  COMMANDER
  CAPTAIN
  COMMODORE
  ADMIRAL
  TOP_DOG
  GRAND_MUFTI
  MEGA_HERO
  GIGA_HERO
}

enum AllianceType {
  NONE
  ASTRO_LEAGUE
  SPACE_DRAGONS
  WARLORD_CONFED
  REBEL_ALLIANCE
}

model Character {
  id              String    @id @default(uuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Identity
  spacerId        Int       @unique @default(autoincrement())
  name            String    // Player name (na$)
  shipName        String?   // Ship name (nz$)
  allianceSymbol  AllianceType @default(NONE)
  
  // Credits (split like original: g1=high, g2=low)
  creditsHigh     Int       @default(0)  // g1 - 10,000s
  creditsLow      Int       @default(0)  // g2 - units (source: start at 0, honorarium applied at creation)
  
  // Personal Bank Account
  bankHigh        Int       @default(0)
  bankLow         Int       @default(0)
  
  // Rank & Progression
  rank            Rank      @default(LIEUTENANT)
  score           Int       @default(0)  // s2 - total points
  promotions      Int       @default(0)  // sc - promotion count
  
  // Vital Stats
  tripsCompleted  Int       @default(0)  // u1
  astrecsTraveled Int       @default(0)  // j1
  cargoDelivered  Int       @default(0)  // k1
  battlesWon      Int       @default(0)  // e1
  battlesLost     Int       @default(0)  // m1
  rescuesPerformed Int      @default(0)  // b1
  
  // Current State
  currentSystem   Int       @default(1)  // sp - current system ID
  tripCount       Int       @default(0)  // z1 - trips today
  lastTripDate    DateTime? @default(now())  // t$ - last trip date
  
  // Mission State
  missionType     Int       @default(0)  // kk - current mission
  cargoPods       Int       @default(0)  // q1
  cargoType       Int       @default(0)  // q2
  cargoPayment    Int       @default(0)  // q5
  destination     Int       @default(0)  // q4
  cargoManifest   String?   // q2$ - cargo description
  raidDocument    String?   // pz$ - owner documents from completed raid (system name)
  
  // Cargo Manifest Board — SP.CARGO.S (4-contract daily board, cc/cs flags)
  manifestBoard   Json?     // 4 daily contracts: array of {cargoType,valuePerPod,dest,destName,payment,distance,fuelRequired}
  manifestDate    String?   // Date string for current manifest (cc flag — regenerate when date changes)

  // Special Flags
  isBot           Boolean   @default(false)
  isConqueror     Boolean   @default(false)
  isLost          Boolean   @default(false)
  lostLocation    Int?
  patrolSector    Int?

  // Space Patrol HQ commission state (SP.REG.S patrol subroutine)
  hasPatrolCommission Boolean   @default(false)  // cs — oath taken at Space Patrol HQ
  patrolBattlesWon    Int       @default(0)       // wb — battles won this patrol mission
  patrolBattlesLost   Int       @default(0)       // lb — battles lost this patrol mission

  // Extra-Curricular Mode (SP.END.txt sp.menu11)
  // P=pirate, S=star_patrol, C=smuggler_patrol, null=none
  extraCurricularMode String?

  // Jail/Crime State (SP.END.S:233-271)
  // crimeType maps to original pp: 5=smuggling, 6=carrier loss, 7=conduct
  crimeType       Int?              // null = not jailed
  sageVisited     Boolean   @default(false)  // Once-per-session Sage flag (kj)
  tripZeroUsed    Boolean   @default(false)  // Once-per-session Algol-2 trip counter zero flag (qu)

  // Black Hole Number Key (SP.PATPIR.S:161-165 "black" section)
  // Set by Wise One (kn variable). Player must enter this to unlock The Great Void weapon enhancement.
  // null means not yet obtained from Wise One.
  numberKey       Int?              // kn (1-9), null = not obtained

  // Nemesis lattice puzzle state (SP.MAL.S nemgem subroutine)
  // Set to true after winning Nemesis battle; cleared when player solves or abandons the lattice
  pendingLattice  Boolean   @default(false) // true = waiting at the crystal lattice

  // Wheel of Fortune daily win tracking (SP.GAME.S lines 47, 53: uh wins vs ui=12 cap)
  wofWinsToday    Int       @default(0)   // uh — wins accumulated today
  wofWinsDate     String?                 // date string (YYYY-MM-DD) of last WOF win day

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  ship            Ship?
  portOwnership   PortOwnership?
  allianceMembership AllianceMembership?
  allianceSystems AllianceSystem[] @relation("AllianceSystemOwner")
  duelEntries     DuelEntry[] @relation("DuelChallenger")
  duelContests    DuelEntry[] @relation("DuelContender")
  battleRecords   BattleRecord[]
  gameLogs        GameLog[]
  travelStates    TravelState[]
  combatSession   CombatSession?
  
  @@index([userId])
  @@index([spacerId])
  @@index([allianceSymbol])
  @@index([rank])
  @@index([isBot])
}

// ============================================================================
// SHIP & COMPONENTS
// ============================================================================

model Ship {
  id              String    @id @default(uuid())
  characterId     String    @unique
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  // Components (strength/condition pairs like original)
  hullStrength    Int       @default(0)
  hullCondition   Int       @default(0)
  driveStrength   Int       @default(0)
  driveCondition  Int       @default(0)
  cabinStrength   Int       @default(0)
  cabinCondition  Int       @default(0)
  lifeSupportStrength Int   @default(0)
  lifeSupportCondition Int  @default(0)
  weaponStrength  Int       @default(0)
  weaponCondition Int       @default(0)
  navigationStrength Int    @default(0)
  navigationCondition Int   @default(0)
  roboticsStrength Int      @default(0)
  roboticsCondition Int     @default(0)
  shieldStrength  Int       @default(0)
  shieldCondition Int       @default(0)
  
  // Resources
  fuel            Int       @default(0)
  cargoPods       Int       @default(0)
  maxCargoPods    Int       @default(0)
  
  // Special Equipment
  hasCloaker      Boolean   @default(false)
  hasAutoRepair   Boolean   @default(false)
  hasStarBuster   Boolean   @default(false)
  hasArchAngel    Boolean   @default(false)
  isAstraxialHull Boolean   @default(false)
  hasTitaniumHull   Boolean   @default(false)
  hasTransWarpDrive Boolean   @default(false)
  hasShipGuard    Boolean   @default(false)   // SP.END.txt: 10,000 cr guard, prevents vandalism on quit
  hasWeaponMark   Boolean   @default(false)   // SP.PATPIR.S blk4: alien enhancement installed (w1$="?"+w1$)
  
  // Component Names (SP.YARD.S tier purchase names)
  hullName        String?
  driveName       String?
  cabinName       String?
  lifeSupportName String?
  weaponName      String?
  navigationName  String?
  roboticsName    String?
  shieldName      String?

  // Damage Tracking (for repair system)
  damageFlags     Json      @default("[]")
  
  updatedAt       DateTime  @updatedAt
  
  @@index([characterId])
}

// ============================================================================
// SPACE PORT OWNERSHIP
// ============================================================================

model PortOwnership {
  id              String    @id @default(uuid())
  characterId     String    @unique
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  systemId        Int       @unique  // Which system owned
  purchaseDate    DateTime  @default(now())
  lastActiveDate  DateTime  @default(now())
  
  // Financials
  fuelPrice       Int       @default(5)   // Owner-set price; original SP.REAL.txt line 97: m5=5
  fuelStored      Int       @default(3000)
  fuelCapacity    Int       @default(20000)
  bankCreditsHigh Int       @default(0)
  bankCreditsLow  Int       @default(0)
  
  // DEFCON (alliance systems)
  defconLevel     Int       @default(0)
  
  // Daily tracking
  dailyLandingFees Int      @default(0)
  dailyFuelSales   Int      @default(0)
  lastFeeCollection DateTime @default(now())
  
  updatedAt       DateTime  @updatedAt
  
  @@index([systemId])
  @@index([characterId])
}

// ============================================================================
// ALLIANCE SYSTEM
// ============================================================================

model AllianceMembership {
  id              String    @id @default(uuid())
  characterId     String    @unique
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  
  alliance        AllianceType
  joinedAt        DateTime  @default(now())
  
  // Investment account
  creditsHigh     Int       @default(0)
  creditsLow      Int       @default(0)
  
  updatedAt       DateTime  @updatedAt
  
  @@index([alliance])
  @@index([characterId])
}

model AllianceSystem {
  id              String    @id @default(uuid())
  systemId        Int       @unique
  alliance        AllianceType
  ownerCharacterId String?
  ownerCharacter  Character? @relation("AllianceSystemOwner", fields: [ownerCharacterId], references: [id])
  defconLevel     Int       @default(1)
  // System treasury assets (SP.VEST.S o3/o4 variables)
  // Stored as raw credit value; original uses 10k-unit split (o3=high, o4=low)
  assetsHigh      Int       @default(0)  // o3 — assets in 10,000 cr units
  assetsLow       Int       @default(0)  // o4 — assets remainder
  // Account password for fortification/withdrawals (SP.VEST.S o7$)
  password        String?
  lastTakeoverAttempt DateTime?

  updatedAt       DateTime  @updatedAt

  @@index([alliance])
  @@index([systemId])
}

// ============================================================================
// STAR SYSTEMS
// ============================================================================

enum SystemType {
  CORE
  RIM
  ANDROMEDA
  SPECIAL
}

model StarSystem {
  id              Int       @id
  name            String    @unique
  coordinates     Json      @default("{\"x\":0,\"y\":0,\"z\":0}")
  type            SystemType @default(CORE)
  features        Json      @default("{}")
  
  // Dynamic state
  portOwner       String?
  fuelPrice       Int       @default(25)
  fuelStored      Int       @default(3000)
  allianceControl AllianceType @default(NONE)
  defconLevel     Int       @default(1)
  
  visitCount      Int       @default(0)
  lastActivity    DateTime  @default(now())
  
  @@index([type])
}

// ============================================================================
// NPC ROSTER (Original SP.FIGHT1.S persistent NPC data files)
// ============================================================================

enum NpcType {
  PIRATE        // PIRATES file (core pirates, kk=1 cargo runs)
  PATROL        // SP.PAT file (space patrol, kk=2/4/5)
  RIM_PIRATE    // SP.RIMPIR file (rim stars, kk=6)
  BRIGAND       // SP.BRIGAND file (smuggling, kk=5 sk=5)
  REPTILOID     // SP.REPTILE file (andromeda, kk=10)
}

model NpcRoster {
  id              String    @id @default(uuid())

  // Identity (original string fields: p3$, p4$, p5$)
  type            NpcType
  shipClass       String    // p3$ - Hull class (e.g. "Junk", "Sailfish", "S1-Snake")
  commander       String    // p4$ - Commander name (e.g. "][-Lt.Savage", "RP-Black Bart")
  shipName        String    // p5$ - Ship name (e.g. "SP1.Thor", "Gypsy Lee")
  homeSystem      String    // p7$ - Home star system name

  // Alliance affiliation (derived from commander prefix in original)
  // K)( = unaffiliated pirate, ][- = patrol, RP- = rim pirate
  // Ship name suffix determines alliance: + = Astro, @ = Dragon, & = Warlord, ^ = Rebel
  alliance        AllianceType @default(NONE)

  // Original numeric fields (p3..s5 from input #1,p3,p4,p5,p6,p7,p8,s7,s8,p9,s9,bl,bw,s3,s4,s5)
  rosterIndex     Int       // p4 - position/ID within original file
  creditValue     Int       // p5 - bounty/credit reward
  fuelCapacity    Int       // p6 - fuel stored

  // Combat components (strength, condition pairs)
  weaponStrength  Int       // p7
  weaponCondition Int       // p8
  shieldStrength  Int       // s7
  shieldCondition Int       // s8
  hullCondition   Int       // p9
  lifeSupportCond Int       // s9
  driveStrength   Int       // s3
  driveCondition  Int       // s4
  hullStrength    Int       // s5

  // Persistent battle record (updated after each fight)
  battlesLost     Int       @default(0) // bl
  battlesWon      Int       @default(0) // bw

  // Seed flag: true for original 65 NPCs, false for generated expansions
  isOriginal      Boolean   @default(false)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  combatSessions  CombatSession[]
  battleRecords   BattleRecord[]

  @@index([type])
  @@index([alliance])
  @@index([isOriginal])
}

// ============================================================================
// COMBAT & BATTLES
// ============================================================================

enum BattleResult {
  VICTORY
  DEFEAT
  RETREAT
  SURRENDER
}

model BattleRecord {
  id              String    @id @default(uuid())
  characterId     String
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  enemyType       String    // pirate, patrol, rim_pirate, etc.
  enemyName       String
  enemyClass      String?
  systemId        Int

  // NPC roster reference (null for legacy/generated enemies)
  npcRosterId     String?
  npcRoster       NpcRoster? @relation(fields: [npcRosterId], references: [id], onDelete: SetNull)

  result          BattleResult
  rounds          Int
  battleFactor    Int

  lootCredits     Int       @default(0)
  damageTaken     Json      @default("{}")

  createdAt       DateTime  @default(now())

  @@index([characterId])
  @@index([createdAt])
  @@index([result])
  @@index([npcRosterId])
}

// ============================================================================
// DUELING ARENA
// ============================================================================

enum DuelStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELLED
}

model DuelEntry {
  id              String    @id @default(uuid())
  challengerId    String
  challenger      Character @relation("DuelChallenger", fields: [challengerId], references: [id], onDelete: Cascade)

  contenderId     String?
  contender       Character? @relation("DuelContender", fields: [contenderId], references: [id], onDelete: SetNull)

  stakesType      String    // points, components, credits
  stakesAmount    Int
  arenaType       Int
  handicap        Int

  status          DuelStatus @default(PENDING)
  result          BattleResult?

  createdAt       DateTime  @default(now())
  completedAt     DateTime?

  @@index([challengerId])
  @@index([status])
  @@index([contenderId])
}

// ============================================================================
// GAME LOGS & EVENTS
// ============================================================================

enum LogType {
  VISITOR
  BATTLE
  TRADE
  PORT_FEE
  PROMOTION
  ACHIEVEMENT
  ALLIANCE
  DUEL
  MISSION
  SYSTEM
  RESCUE
  CONQUEST
  HERO
}

model GameLog {
  id              String    @id @default(uuid())
  type            LogType
  characterId     String?
  character       Character? @relation(fields: [characterId], references: [id], onDelete: SetNull)
  systemId        Int?
  message         String
  metadata        Json?
  
  createdAt       DateTime  @default(now())
  
  @@index([type])
  @@index([createdAt])
  @@index([characterId])
}

// ============================================================================
// COMBAT STATE (for disconnect mitigation)
// ============================================================================

model CombatSession {
  id              String    @id @default(uuid())
  characterId     String    @unique
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  // NPC roster reference (for identity persistence across disconnect)
  npcRosterId     String?
  npcRoster       NpcRoster? @relation(fields: [npcRosterId], references: [id], onDelete: SetNull)

  // Enemy identity for salvage/tribute calculations (SP.FIGHT2.S)
  enemyType       String    @default("PIRATE")  // PIRATE, PATROL, RIM_PIRATE, BRIGAND, REPTILOID
  enemyName       String    @default("")         // p5$ - ship name

  playerWeaponPower   Int
  playerShieldPower   Int
  playerDrivePower    Int
  playerBattleFactor  Int

  enemyWeaponPower    Int
  enemyShieldPower    Int
  enemyDrivePower     Int
  enemyBattleFactor   Int
  enemyHullCondition  Int       @default(5)

  currentRound    Int         @default(1)
  active          Boolean     @default(true)
  result          String?     // VICTORY, DEFEAT, DRAW

  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([characterId])
  @@index([active])
  @@index([npcRosterId])
}

// ============================================================================
// ALLIANCE BULLETIN BOARD (SP.TOP.S)
// ============================================================================

model BulletinPost {
  id              String    @id @default(uuid())
  alliance        AllianceType
  authorName      String
  characterId     String?
  message         String
  createdAt       DateTime  @default(now())

  @@index([alliance])
  @@index([createdAt])
}

// ============================================================================
// TRAVEL STATE (for real-time tracking)
// ============================================================================

model TravelState {
  id              String    @id @default(uuid())
  characterId     String    @unique
  character       Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  originSystem    Int
  destinationSystem Int
  departureTime   DateTime
  expectedArrival DateTime
  fuelReserved    Int
  inTransit       Boolean   @default(true)
  
  // Black hole transit flag (SP.WARP.S bh variable)
  // Set to true after transiting black hole on Andromeda mission (kk=10)
  // Required before course changes are allowed in Andromeda space
  blackHoleTransited Boolean @default(false)

  @@index([characterId])
  @@index([inTransit])
}

// ============================================================================
// GAME CONFIGURATION (SP.EDIT3 sp.conf — sysop-tunable battle/difficulty settings)
// ============================================================================

model GameConfig {
  id                    String   @id @default("default")
  battleDifficulty      Int      @default(5)    // ff: 1-9
  maxCombatRounds       Int      @default(12)   // qq: 1-15
  pirateAttackThreshold Int      @default(20)   // jw
  patrolAttackThreshold Int      @default(25)   // jx
  attackRandomMin       Int      @default(3)    // ju: 1-9
  attackRandomMax       Int      @default(5)    // jv: 1-9
  updatedAt             DateTime @updatedAt
}
