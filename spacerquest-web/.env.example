# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://spacerquest:spacerquest@localhost:5432/spacerquest

# Redis
REDIS_URL=redis://localhost:6379

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long

# OAuth (BBS Portal) - Replace with actual values
BBS_PORTAL_CLIENT_ID=your-client-id
BBS_PORTAL_CLIENT_SECRET=your-client-secret
BBS_PORTAL_AUTH_URL=https://bbs-portal.example.com/oauth/authorize
BBS_PORTAL_TOKEN_URL=https://bbs-portal.example.com/oauth/token
BBS_PORTAL_CALLBACK_URL=http://localhost:3000/auth/callback
BBS_PORTAL_USERINFO_URL=https://bbs-portal.example.com/api/user

# Session
SESSION_MAX_AGE=2592000000

# Game Configuration
DAILY_TRIP_LIMIT=3
ENCOUNTER_CHANCE=0.3
PORT_EVICTION_DAYS=30
STARTING_CREDITS_NEW=1000
STARTING_CREDITS_CONQUEROR=10000
